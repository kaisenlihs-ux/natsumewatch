DATABASE_URL=sqlite+aiosqlite:///./natsumewatch.db
JWT_SECRET=change-me-in-production-please
CORS_ORIGINS=http://localhost:3000

# OAuth (optional). Empty client_id disables the provider.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public origin where this API is reachable; used to build the OAuth
# redirect URI registered with the provider.
OAUTH_REDIRECT_BASE=
# Origin of the frontend the OAuth callback should land back on.
FRONTEND_BASE_URL=
